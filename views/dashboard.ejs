<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=<device-width>, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="sidebar">
        <h2>Library</h2>
        <a href="/">Dashboard</a>
        <a href="/books">Books</a>
        <a href="/borrowed">Borrowed Books</a>
        <a href="/students">Students</a>
        <a href="/logout" onclick="localStorage.removeItem('loginTime')">Logout</a>
    </div>
    <div class="section">
        <div class="main">
            <h1>Welcome <%= librarian.NAME %>
            </h1>
        </div>
        <div class="set">
            <div class="card">
                <h2>Total Books <br><span class="center">
                        <%= totalBooks %>
                    </span></h2>
            </div>
            <div class="card">
                <h2>Total Borrowed <br><span class="center">
                        <%= totalBorrowed %>
                    </span></h2>
            </div>
            <div class="card">
                <h2>Total Visits <br><span class="center">
                        <%= totalVisits %>
                    </span></h2>
            </div>
        </div>
        <p id="clock" style="font-size:32px; font-weight:bold; color:#5B4B8A; margin-top:20px;"></p>

        <p id="clock" style="font-size:32px; font-weight:bold; color:#5B4B8A; margin-top:20px;">
        </p>

        <script>
            if (!localStorage.getItem('loginTime')) {
                localStorage.setItem('loginTime', new Date().getTime());
            }

            function updateClock() {
                const loginTime = parseInt(localStorage.getItem('loginTime'));
                const diff = Math.floor((new Date().getTime() - loginTime) / 1000);

                const hrs = String(Math.floor(diff / 3600)).padStart(2, '0');
                const mins = String(Math.floor((diff % 3600) / 60)).padStart(2, '0');
                const secs = String(diff % 60).padStart(2, '0');

                document.getElementById('clock').innerText = `Time on site: ${hrs}:${mins}:${secs}`;
            }

            setInterval(updateClock, 1000);
            updateClock();
        </script>
    </div>
</body>

</html>